# Akulaku API Credentials
# Dapatkan dari https://developer.akulaku.com → Console → App Management

AKULAKU_APP_KEY=your_app_key_here
AKULAKU_APP_SECRET=your_a...n
# API Base URL (default)
AKULAKU_API_BASE=https://open.akulaku.com/api

# Telegram Notifications (optional)
AKULAKU_NOTIFICATION_TELEGRAM=false
AKULAKU_TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=

# Auto Features (optional)
AKULAKU_AUTO_ACCEPT=false
AKULAKU_AUTO_REPLY=false
AKULAKU_AUTO_PROMO=false

# Polling Interval (seconds)
AKULAKU_POLL_INTERVAL=60

# Rate Limiting
AKULAKU_REQUEST_DELAY=1.0
